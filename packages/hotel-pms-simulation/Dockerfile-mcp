# Multi-stage Dockerfile for Hotel Assistant MCP Server
# Optimized for MCP server deployment

FROM public.ecr.aws/docker/library/python:3.14-slim AS builder

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Download and install uv
RUN curl -LsSf https://astral.sh/uv/install.sh -o /uv-installer.sh && \
    sh /uv-installer.sh && rm /uv-installer.sh

# Ensure uv is on PATH
ENV PATH="/root/.local/bin/:$PATH"

# Enable bytecode compilation for faster startup
ENV UV_COMPILE_BYTECODE=1

# Use copy link mode to avoid warnings about hard links
ENV UV_LINK_MODE=copy

# Set working directory
WORKDIR /app

# Copy package configuration
COPY pyproject.toml uv.lock ./
COPY README.md ./

# Install dependencies only (not the project itself)
# This layer is cached unless dependencies change
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project

# Copy source code
COPY hotel_pms_simulation/ ./hotel_pms_simulation/

# Install the project in non-editable mode
RUN uv sync --frozen --no-dev --no-editable

# Final stage - minimal runtime image
FROM public.ecr.aws/docker/library/python:3.14-slim

# Install only curl for health checks
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN addgroup --system --gid 1001 appgroup && \
    adduser --system --uid 1001 --gid 1001 appuser

# Set working directory
WORKDIR /app

# Copy the virtual environment from builder
COPY --from=builder --chown=appuser:appgroup /app/.venv /app/.venv

# Set environment variables
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH="/app"

# Switch to non-root user
USER appuser

# Expose standard MCP port (required by AgentCore Runtime)
EXPOSE 8000

# Add healthcheck using the custom health endpoint
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/ping || exit 1

# Use the MCP server as entry point
# The server will be available at:
# - MCP endpoint: http://0.0.0.0:8000/mcp
# - Health check: http://0.0.0.0:8000/health
# - Ping: http://0.0.0.0:8000/ping
ENTRYPOINT ["python", "-m", "hotel_pms_simulation.mcp.server"]
