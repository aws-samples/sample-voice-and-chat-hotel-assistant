# Hotel Assistant Chat Agent Configuration
# Copy this file to .env and update with your actual values

# Hotel PMS MCP Server Configuration
# Choose ONE of the following configuration methods:

# Option 1: Use AWS Secrets Manager (recommended for production)
# HOTEL_PMS_MCP_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:hotel-pms-mcp-config

# Option 2: Use individual environment variables (for development)
HOTEL_PMS_MCP_URL=https://your-agentcore-gateway.gateway.bedrock-agentcore.us-east-1.amazonaws.com/mcp
HOTEL_PMS_MCP_CLIENT_ID=your-cognito-client-id
HOTEL_PMS_MCP_CLIENT_SECRET=your-cognito-client-secret
HOTEL_PMS_MCP_USER_POOL_ID=us-east-1_YourUserPool

# AWS Region
AWS_REGION=us-east-1

# Optional: Connection Configuration
HOTEL_PMS_MCP_TIMEOUT=30
HOTEL_PMS_MCP_MAX_RETRIES=3

# Bedrock Model Configuration
BEDROCK_MODEL_ID=global.amazon.nova-2-lite-v1:0
# Model temperature (0.0-1.0): Controls randomness in responses. Lower = more focused, Higher = more creative
MODEL_TEMPERATURE=0.2

# AgentCore Memory Configuration
# Memory ID should be set by infrastructure (CDK/CloudFormation)
AGENTCORE_MEMORY_ID=mem-12345abcdef
# Number of conversation turns to load (default: 30)
AGENTCORE_MEMORY_MAX_TURNS=30

# Logging Configuration
LOG_LEVEL=INFO
