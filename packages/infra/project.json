{
  "name": "infra",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/infra",
  "targets": {
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdk deploy --all --require-approval=never",
        "cwd": "packages/infra"
      },
      "configurations": {
        "virtual-assistant": {
          "command": "cdk deploy VirtualAssistantStack --require-approval=never"
        },
        "hotel-pms": {
          "command": "cdk deploy HotelPmsStack --require-approval=never"
        }
      },
      "dependsOn": [
        "frontend:build",
        "constructs:package:python",
        "hotel-pms-simulation:package",
        "hotel-pms-simulation:prepare-deployment-spec",
        "virtual-assistant-messaging-lambda:package",
        "chatbot-messaging-backend:package"
      ]
    },
    "diff": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdk diff --all",
        "cwd": "packages/infra"
      },
      "configurations": {
        "virtual-assistant": {
          "command": "cdk diff VirtualAssistantStack"
        },
        "hotel-pms": {
          "command": "cdk diff HotelPmsStack"
        }
      },
      "dependsOn": [
        "frontend:build",
        "constructs:package:python",
        "hotel-pms-simulation:prepare-deployment-spec",
        "hotel-pms-simulation:package",
        "virtual-assistant-messaging-lambda:package",
        "chatbot-messaging-backend:package"
      ]
    },
    "synth": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdk synth",
        "cwd": "packages/infra"
      },
      "dependsOn": [
        "frontend:build",
        "constructs:package:python",
        "hotel-pms-simulation:package",
        "hotel-pms-simulation:prepare-deployment-spec",
        "virtual-assistant-messaging-lambda:package",
        "chatbot-messaging-backend:package"
      ]
    },
    "destroy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdk destroy --all",
        "cwd": "packages/infra"
      },
      "configurations": {
        "virtual-assistant": {
          "command": "cdk destroy VirtualAssistantStack"
        },
        "hotel-pms": {
          "command": "cdk destroy HotelPmsStack"
        }
      }
    },
    "bootstrap": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cdk bootstrap",
        "cwd": "packages/infra"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync",
        "cwd": "packages/infra"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest",
        "cwd": "packages/infra"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ruff check .",
        "cwd": "packages/infra"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ruff format .",
        "cwd": "packages/infra"
      }
    }
  },
  "tags": ["python", "type:infra", "scope:backend"]
}
