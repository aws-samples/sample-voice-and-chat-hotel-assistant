{
  "name": "@virtual-assistant/workspace",
  "version": "1.0.0",
  "description": "Virtual Assistant - Full Stack Application",
  "type": "module",
  "private": true,
  "license": "MIT-0",
  "scripts": {
    "dev": "nx serve frontend",
    "build": "nx build frontend",
    "build:all": "nx run-many -t build",
    "test": "nx test frontend",
    "test:load": "nx test load-test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:all": "nx run-many -t lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:all": "nx run-many -t format",
    "preview": "nx preview frontend",
    "deploy": "nx deploy infra",
    "deploy:diff": "nx diff infra",
    "deploy:destroy": "nx destroy infra",
    "deploy:nova-sonic": "nx deploy:nova-sonic infra",
    "deploy:hotel-pms": "nx deploy:hotel-pms infra",
    "deploy:diff:nova-sonic": "nx diff:nova-sonic infra",
    "deploy:diff:hotel-pms": "nx diff:hotel-pms infra",
    "deploy:destroy:nova-sonic": "nx destroy:nova-sonic infra",
    "deploy:destroy:hotel-pms": "nx destroy:hotel-pms infra",
    "postinstall": "nx run-many -t install --projects=tag:python",
    "clean": "pnpm -r exec rm -rf node_modules && rm -rf node_modules && nx reset"
  },
  "devDependencies": {
    "@cloudscape-design/components": "^3.0.933",
    "@cloudscape-design/global-styles": "^1.0.43",
    "@eslint/js": "9.32.0",
    "@nx/eslint": "21.3.10",
    "@nx/vite": "21.3.10",
    "@nx/workspace": "21.4.1",
    "@tanstack/react-query": "5.87.4",
    "@tanstack/react-router": "^1.87.4",
    "@tanstack/router-plugin": "^1.87.4",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.8.2",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.13.5",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript-eslint": "^8.57.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.0",
    "nx": "21.3.10",
    "pnpm": "^10.29.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-oidc-context": "^3.2.0",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3",
    "unified": "11.0.5",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<5.1.8": "^5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "ajv@>=8.0.0 <8.18.0": "^8.18.0"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
